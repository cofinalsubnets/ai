#!/bin/sh
# Keep committed build artifacts in lockstep with the sources they are built
# from. wasm/ai.js (the page's engine) ships from the repo, so when a commit
# touches what it is built from, rebuild it and stage it -- the committed blob
# then never lags the committed code.
#
# wasm bakes the C core + prel/ev/egg ONLY (not the test corpus, not repl/cli),
# so only those sources trigger its rebuild; a test/*.l (the spec included) edit
# leaves ai.js untouched. It builds from the working tree, so stage your
# artifact-affecting changes before committing (the normal flow).
#
# Installed via `git config core.hooksPath .githooks` (run `make hooks`).
# Bypass for a one-off with `git commit --no-verify`.

staged=$(git diff --cached --name-only --diff-filter=ACMR)
status=0

# wasm/ai.js -- needs emcc; skip (with a warning) when it is absent.
if printf '%s\n' "$staged" | grep -qE \
  '^(ai\.c|[^/]+\.h|ai/(prel|ev|egg)\.l|wasm/(host\.c|Makefile|inc/.+\.h))$'; then
  if command -v emcc >/dev/null 2>&1; then
    echo "pre-commit: ai.js sources changed, rebuilding wasm/ai.js ..." >&2
    if make wasm >/dev/null 2>&1; then git add wasm/ai.js
    else echo "pre-commit: 'make wasm' failed -- fix the build, or commit with --no-verify" >&2; status=1
    fi
  else
    echo "pre-commit: emcc not found -- wasm/ai.js may be stale (skipping rebuild)" >&2
  fi
fi

# bench/bench.html -- the results page. Rebuild when something that moves the
# numbers is touched (the core, the egg layers, the glaze, the benches, the
# harness). `make -C bench html` re-renders from the cached out/bench/*.txt,
# re-running only the STALE columns (ai, when the binary changed) and reusing
# the cache for the rest -- so a warm cache makes this seconds, not minutes.
# NON-FATAL: a cold cache or a missing language runtime must not block a commit.
# (bench.html itself is excluded from the trigger so committing the page can't loop.)
if printf '%s\n' "$staged" | grep -qE \
  '^(ai\.c|[^/]+\.h|ai/(prel|ev)\.l|ai/glaze/[^/]+\.l|bench/(benches/.+|bench\.l|run\.sh|mkhtml\.sh|report\.awk|Makefile))$'; then
  echo "pre-commit: bench sources changed, rebuilding bench/bench.html ..." >&2
  if make -C bench html >/dev/null 2>&1; then git add bench/bench.html
  else echo "pre-commit: 'make -C bench html' failed (cold cache?) -- bench.html may lag (commit with --no-verify to skip)" >&2
  fi
fi

exit $status
