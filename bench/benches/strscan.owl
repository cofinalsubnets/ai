; fixed string built once; the timed work is a linear rolling-hash scan.
(define hmod 1000000007)
(define data
  (list->string (let loop ((i 0) (a '()))
                  (if (< i 20000) (loop (+ i 1) (cons (+ 32 (modulo (* 7 i) 95)) a)) (reverse a)))))
(bench "strscan"
  (lambda ()
    (let hloop ((j 0) (h 0))
      (if (< j (string-length data))
          (hloop (+ j 1) (modulo (+ (* h 31) (string-ref data j)) hmod))
          h))))
